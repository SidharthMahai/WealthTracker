# Workbook storage (recommended for Vercel)
# Create a Vercel Blob store and upload your workbook there.
# Set this to the blob pathname, for example:
# PORTFOLIO_BLOB_PATHNAME=wealthtracker/Investment-Tracker.xlsx
PORTFOLIO_BLOB_PATHNAME=

# Optional: "private" (default) or "public".
PORTFOLIO_BLOB_ACCESS=private

# Local workbook fallback (used when PORTFOLIO_BLOB_PATHNAME is empty).
PORTFOLIO_WORKBOOK_PATH=data/Investment-Tracker.xlsx

# Required in production (set this in Vercel project env vars).
WEALTHTRACKER_PASSWORD=
